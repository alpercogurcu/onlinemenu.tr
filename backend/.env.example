# =============================================================================
# .env.example — Lokal geliştirme ortamı şablonu
# Kopyala: cp .env.example .env
# Gerçek sırlar için sops:decrypt kullan; .env asla git'e commit edilmez.
# =============================================================================

# ── Uygulama ──────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_VERSION=dev
HTTP_ADDR=:8080

# ── PostgreSQL (app_runtime rolü — RLS zorunlu) ───────────────────────────────
# docker-compose postgres servisine karşılık gelir (port 5445).
DATABASE_URL=postgres://app_runtime:runtime_secret@localhost:5445/onlinemenu?sslmode=disable

# Outbox dispatcher AYRI bir bağlantı kullanır (app_migrator rolü ile).
# OUTBOX_MIGRATOR_DSN boş bırakılırsa dispatcher devre dışı kalır ve events DB'de birikir.
# NOT: task migrate:up/down/verify de bu değişkeni kullanır — cmd/migrate RLS
# FORCE nedeniyle tablo sahibi rol (app_migrator) gerektirir ve yalnızca
# "pgx5://" şemasını tanır (golang-migrate pgx/v5 driver). Taskfile bu DSN'i
# "postgres://" → "pgx5://" dönüştürerek DATABASE_URL olarak cmd/migrate'e
# aktarır — DATABASE_URL'i (app_runtime, postgres://) doğrudan kullanmaz.
OUTBOX_MIGRATOR_DSN=postgres://app_migrator:migrator_secret@localhost:5445/onlinemenu?sslmode=disable

# ── NATS JetStream ─────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── HashiCorp Vault ────────────────────────────────────────────────────────────
# Dev modunda Vault dev sunucu (stateless, restart ile sıfırlanır).
VAULT_ADDR=http://localhost:8210
VAULT_TOKEN=dev-root-token

# ── Kimlik ────────────────────────────────────────────────────────────────────
# Context token imzalama anahtarı (en az 32 byte, rastgele üret).
# Üretim: openssl rand -hex 32
CTX_TOKEN_SECRET=dev-secret-change-in-production-do-not-use

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_BUNDLE_PATH=configs/opa/bundles
